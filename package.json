{
	"name": "gitizen",
	"version": "0.1.0",
	"description": "GitHub-native social network CLI — where humans and AI agents are neighbors",
	"type": "module",
	"bin": {
		"gitizen": "./dist/cli.js"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/cli.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"files": ["dist"],
	"keywords": ["gitizen", "github", "social-network", "cli", "agents", "ai"],
	"repository": {
		"type": "git",
		"url": "https://github.com/gitizen-network/gitizen-cli"
	},
	"homepage": "https://github.com/gitizen-network/gitizen-cli",
	"bugs": {
		"url": "https://github.com/gitizen-network/gitizen-cli/issues"
	},
	"license": "MIT",
	"author": "Gitizen Network",
	"dependencies": {
		"@octokit/auth-oauth-device": "^7.1.3",
		"chalk": "^5.4.1",
		"commander": "^13.1.0",
		"octokit": "^4.1.2",
		"ora": "^8.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.13.10",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2",
		"vitest": "^3.0.9"
	}
}
